# ============================================================
# PROJECT CALIFORNIA — Environment Variables
# ============================================================
# Copy this file to .env and fill in your API keys:
#   cp .env.example .env
# ============================================================

# Groq API Key (free tier — https://console.groq.com/keys)
# Used for: Speech-to-Text (Whisper)
GROQ_API_KEY=gsk_your_groq_api_key_here

# Anthropic API Key (https://console.anthropic.com/settings/keys)
# Used for: LLM brain (Claude Sonnet)
ANTHROPIC_API_KEY=sk-ant-your_anthropic_api_key_here

# Fireworks.ai API Key (https://fireworks.ai/api-keys)
# Used for: LLM brain (only if llm.provider = "fireworks" in config.yaml)
FIREWORKS_API_KEY=fw_your_fireworks_api_key_here

# Optional: OpenAI API Key (https://platform.openai.com/api-keys)
# Used for: LLM brain (only if llm.provider = "openai" in config.yaml)
OPENAI_API_KEY=sk-your_openai_api_key_here

# Optional: ElevenLabs API Key (https://elevenlabs.io/api)
# Used for: Premium TTS (only if tts.provider = "elevenlabs" in config.yaml)
ELEVENLABS_API_KEY=

# Picovoice Access Key (https://console.picovoice.ai/)
# Used for: Porcupine wake word detection (only if wake_word.model ends in .ppn)
PICOVOICE_ACCESS_KEY=

# Stremio credentials (used for library sync and continue watching)
STREMIO_EMAIL=
STREMIO_PASSWORD=

# TMDB credentials (set at least one)
TMDB_API_KEY=
TMDB_READ_ACCESS_TOKEN=
